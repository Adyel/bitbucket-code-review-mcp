# Bitbucket Code Review MCP - Environment Variables

# Required: Bitbucket Cloud credentials
BITBUCKET_EMAIL=your-atlassian-email@example.com
BITBUCKET_API_TOKEN=your-api-token

# Optional: Default workspace and repo (avoids specifying them in every tool call)
BITBUCKET_DEFAULT_WORKSPACE=
BITBUCKET_DEFAULT_REPO_SLUG=

# Optional: Customize the AI review tag (default: 🤖 AI Review)
# Set to empty string to disable tagging: BITBUCKET_AI_TAG=
BITBUCKET_AI_TAG=🤖 AI Review

# Optional: Create comments as pending/draft (default: false)
# When true, comments are not published until the reviewer submits the review
BITBUCKET_COMMENTS_PENDING=false
