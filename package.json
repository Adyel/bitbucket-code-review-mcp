    "model-context-protocol",
    "ai-review",
    "gemini-cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adyel/bitbucket-code-review-mcp.git"
  },
  "homepage": "https://github.com/Adyel/bitbucket-code-review-mcp#readme",
  "bugs": {
    "url": "https://github.com/Adyel/bitbucket-code-review-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
