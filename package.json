{
  "name": "bitbucket-code-review-mcp",
  "version": "1.0.0",
  "description": "MCP server for posting code review comments on Bitbucket Cloud pull requests",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bitbucket-code-review-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "bitbucket",
    "code-review",
